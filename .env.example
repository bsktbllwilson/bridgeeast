# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin (single value used by older code; comma-separated list used by newer code)
ADMIN_EMAIL=admin@passtheplate.store
ADMIN_EMAILS=admin@passtheplate.store
NEXT_PUBLIC_ADMIN_EMAIL=admin@passtheplate.store
ADMIN_NOTIFICATIONS_EMAIL=admin@passtheplate.store

# Email (Resend)
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=Pass The Plate <noreply@passtheplate.store>

# On-demand translation (Anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Analytics (PostHog) — optional
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# SEO — optional
GOOGLE_SITE_VERIFICATION=
