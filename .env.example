# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used by metadataBase, OAuth redirects, emails)
NEXT_PUBLIC_SITE_URL=https://passtheplate.store

# Resend — transactional email (inquiries to sellers, partner-app
# admin notifications). Get from https://resend.com/api-keys. Leave
# blank to no-op (DB inserts still happen; just no email is sent).
RESEND_API_KEY=
RESEND_FROM_EMAIL=Pass The Plate <noreply@passtheplate.store>
# Receives admin alerts: new partner applications, etc.
ADMIN_NOTIFICATIONS_EMAIL=

# Mapbox — Listing Hotspots map on /sell.
# Get a public token at https://account.mapbox.com/access-tokens/.
# Restrict it to your production + preview domains. Leave blank to
# render a fallback list instead of the map.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Stripe — membership subscriptions on /membership.
# Get keys at https://dashboard.stripe.com/apikeys. Use test keys
# locally and switch to live in production. Leave STRIPE_SECRET_KEY
# blank to disable Checkout (the page still renders; clicking Start
# Plan returns 503).
STRIPE_SECRET_KEY=
# From https://dashboard.stripe.com/webhooks (one signing secret per
# endpoint). Configure the endpoint to https://passtheplate.store/api/
# stripe/webhook and subscribe to: checkout.session.completed,
# customer.subscription.updated, customer.subscription.deleted.
STRIPE_WEBHOOK_SECRET=
# Recurring price IDs from your Stripe Dashboard (Products → Pricing).
STRIPE_PRICE_CHEFS_TABLE=
STRIPE_PRICE_FULL_MENU=

# --- Supabase dashboard config (set these in the Supabase web UI) ---
# Authentication → URL Configuration:
#   Site URL:                     https://passtheplate.store
#   Additional Redirect URLs:     http://localhost:3000/**
#                                 https://*.vercel.app/**
