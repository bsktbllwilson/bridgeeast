# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used by metadataBase, OAuth redirects, emails)
NEXT_PUBLIC_SITE_URL=https://passtheplate.store

# Resend — transactional email (inquiries to sellers).
# Get from https://resend.com/api-keys. Leave blank to no-op (inquiry
# still inserts to listing_inquiries; just no email is sent).
RESEND_API_KEY=
RESEND_FROM_EMAIL=Pass The Plate <noreply@passtheplate.store>

# --- Supabase dashboard config (set these in the Supabase web UI) ---
# Authentication → URL Configuration:
#   Site URL:                     https://passtheplate.store
#   Additional Redirect URLs:     http://localhost:3000/**
#                                 https://*.vercel.app/**
